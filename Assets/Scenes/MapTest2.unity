    displayDuration: 2.5
    sfxOnStart: {fileID: 8300000, guid: 4624036e487109a409c057f9191d5a85, type: 3}
    imageLayout:
      anchoredPosition: {x: 22.5, y: -242}
      size: {x: 573, y: 2007}
  - speakerName: Perfume
    dialogueText: "H\xF4m nay, ch\xFAng t\xF4i v\u1EEBa nh\u1EADp \u0111\u01B0\u1EE3c
      1 s\u1ED1 h\xE0ng t\u1ED1t , m\u1EDDi b\u1EA1n xem qua"
    npcImage: {fileID: 21300000, guid: 2e9cd8cc6d3cd154aa64f22e8a3e4615, type: 3}
