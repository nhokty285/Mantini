      anchoredPosition: {x: 22.5, y: -242}
      size: {x: 573, y: 2007}
  - speakerName: Perfume
    dialogueText: "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn v\u1EDBi c\u1EEDa h\xE0ng
      n\u01B0\u1EDBc hoa  , t\xF4i c\xF3 th\u1EC3 gi\xFAp g\xEC \u0111\u01B0\u1EE3c
      cho b\u1EA1n"
