  dialogueSequence:
  - speakerName: Perfume
    dialogueText: "Bu\u1ED5i s\xE1ng t\u1ED1t l\xE0nh"
    npcImage: {fileID: 21300000, guid: 2e9cd8cc6d3cd154aa64f22e8a3e4615, type: 3}
    displayDuration: 2
    sfxOnStart: {fileID: 8300000, guid: 151d3c9cfa5c3fb4eacc47de4dedac5e, type: 3}
