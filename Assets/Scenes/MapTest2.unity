  dialogueSequence:
  - speakerName: Glass
    dialogueText: "Xin ch\xE0o"
    npcImage: {fileID: 21300000, guid: 5c3a76233aa99eb41abe1671c6dba1a1, type: 3}
    displayDuration: 2
    sfxOnStart: {fileID: 8300000, guid: 6daa72f7ef209db4cbab45e3eeaf6de0, type: 3}
    imageLayout:
      anchoredPosition: {x: 8, y: -131}
      size: {x: 573, y: 1944}
  - speakerName: Glass
    dialogueText: "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn v\u1EDBi c\u1EEDa h\xE0ng
      m\u1EAFt k\xEDnh , t\xF4i c\xF3 th\u1EC3 gi\xFAp g\xEC \u0111\u01B0\u1EE3c
      cho b\u1EA1n"
    npcImage: {fileID: 21300000, guid: 5c3a76233aa99eb41abe1671c6dba1a1, type: 3}
    displayDuration: 2.5
    sfxOnStart: {fileID: 8300000, guid: 958fad3758d723148b51a32ef13a877f, type: 3}
    imageLayout:
      anchoredPosition: {x: 8, y: -131}
      size: {x: 573, y: 1944}
  - speakerName: Glass
    dialogueText: "H\xF4m nay, ch\xFAng t\xF4i v\u1EEBa nh\u1EADp \u0111\u01B0\u1EE3c
      1 s\u1ED1 h\xE0ng t\u1ED1t , m\u1EDDi b\u1EA1n xem qua"
    npcImage: {fileID: 21300000, guid: 5c3a76233aa99eb41abe1671c6dba1a1, type: 3}
    displayDuration: 2
    sfxOnStart: {fileID: 0}
