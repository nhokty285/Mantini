  m_Name: 
  m_EditorClassIdentifier: 
  npcName: Leather
  npcId: 1
  npcType: 0
  interactionRange: 10
  npcIcon: {fileID: 21300000, guid: af460c9776aa5204a8f5b38692dfd925, type: 3}
  dialogueSequence:
  - speakerName: Leather
    dialogueText: "Xin ch\xE0o"
    npcImage: {fileID: 21300000, guid: 4d9593eee57f69b43a2469295eaa3458, type: 3}
    displayDuration: 2
    sfxOnStart: {fileID: 8300000, guid: 94c6f21025d83d640b15ba5ddfbd67d6, type: 3}
    imageLayout:
      anchoredPosition: {x: 8, y: -131}
      size: {x: 513, y: 1938}
  - speakerName: Leather
    dialogueText: "Ch\xE0o m\u1EEBng b\u1EA1n \u0111\u1EBFn v\u1EDBi c\u1EEDa h\xE0ng
      \u0111\u1ED3 da, t\xF4i c\xF3 th\u1EC3 gi\xFAp g\xEC \u0111\u01B0\u1EE3c cho
      b\u1EA1n"
    npcImage: {fileID: 21300000, guid: 4d9593eee57f69b43a2469295eaa3458, type: 3}
    displayDuration: 2.5
    sfxOnStart: {fileID: 8300000, guid: 5007cd57efc6192488250f7488cbf487, type: 3}
    imageLayout:
      anchoredPosition: {x: 8, y: -131}
      size: {x: 513, y: 1938}
  - speakerName: Leather
    dialogueText: "H\xF4m nay, ch\xFAng t\xF4i v\u1EEBa nh\u1EADp \u0111\u01B0\u1EE3c
      1 s\u1ED1 h\xE0ng t\u1ED1t , m\u1EDDi b\u1EA1n xem qua"
    npcImage: {fileID: 21300000, guid: 4d9593eee57f69b43a2469295eaa3458, type: 3}
    displayDuration: 2
    sfxOnStart: {fileID: 0}
    imageLayout:
      anchoredPosition: {x: 8, y: -131}
      size: {x: 513, y: 1938}
